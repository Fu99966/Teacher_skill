# Required: enable real OpenAI-compatible generation.
# Never commit your real API key.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Optional: keep DeepSeek for field-level refine/review fallback.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT=90

# V10 generation is template-driven and uses OPENAI_API_KEY.
