# Optional: enable real DeepSeek generation.
# Never commit your real API key.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT=90

# V8 recommends strict mode in the web UI:
# - strict AI mode ON: DeepSeek failure stops generation and shows the reason.
# - strict AI mode OFF: falls back to a local draft for offline demos.
